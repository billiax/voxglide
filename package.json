{
  "name": "voxglide",
  "version": "0.2.2",
  "description": "Embeddable voice AI SDK for web pages — form filling, navigation, Q&A via speech recognition and server proxy",
  "author": "Billiax",
  "license": "MIT",
  "type": "module",
  "main": "dist/voice-sdk.esm.js",
  "module": "dist/voice-sdk.esm.js",
  "types": "dist/index.d.ts",
  "browser": "dist/voice-sdk.iife.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/voice-sdk.esm.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/billiax/voxglide.git"
  },
  "homepage": "https://github.com/billiax/voxglide",
  "bugs": {
    "url": "https://github.com/billiax/voxglide/issues"
  },
  "keywords": [
    "voice",
    "ai",
    "speech-recognition",
    "form-filling",
    "accessibility",
    "sdk",
    "web-speech-api",
    "voice-assistant"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "rollup -c rollup.config.mjs",
    "dev": "rollup -c rollup.config.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "check": "npm run typecheck && npm run lint && npm run test",
    "prepublishOnly": "npm run check && npm run build"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-terser": "^0.4.0",
    "@rollup/plugin-typescript": "^12.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "jsdom": "^28.1.0",
    "rollup": "^4.0.0",
    "tslib": "^2.8.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.18"
  }
}
