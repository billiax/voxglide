{
  "name": "voice-sdk",
  "version": "0.1.0",
  "description": "Embeddable voice AI SDK for web pages — form filling, navigation, Q&A via Gemini Native Audio",
  "type": "module",
  "main": "dist/voice-sdk.esm.js",
  "module": "dist/voice-sdk.esm.js",
  "types": "dist/index.d.ts",
  "browser": "dist/voice-sdk.iife.js",
  "exports": {
    ".": {
      "import": "./dist/voice-sdk.esm.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.mjs",
    "dev": "rollup -c rollup.config.mjs --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@google/genai": ">=0.7.0"
  },
  "devDependencies": {
    "@google/genai": "^0.14.0",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-terser": "^0.4.0",
    "@rollup/plugin-typescript": "^12.0.0",
    "rollup": "^4.0.0",
    "tslib": "^2.8.0",
    "typescript": "^5.6.0"
  },
  "license": "MIT"
}
